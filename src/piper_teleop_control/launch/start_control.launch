<launch>
    <group ns="left_arm">
        <remap from="/joint_states" to="/left_arm/joint_states" />
    </group>
    <group ns="right_arm">
        <remap from="/joint_states" to="/right_arm/joint_states" />
    </group>

    <node pkg="piper_teleop_control" type="dual_arm_follower.py" name="piper_dual_arm_follower" output="screen"/>
</launch>
